---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import profile from '../data/profile.json';

const allPublications = await getCollection('publications');
const publications = allPublications
  .sort((a, b) => b.data.year - a.data.year)
  .map((pub) => ({
    ...pub.data,
    abstract: pub.body.trim(),
  }));
---

<Layout
  title="Research — Lorenzo Coviello"
  description="Research and publications by Lorenzo Coviello"
>
  <Nav current="research" />

  <main class="max-w-4xl mx-auto px-6 pt-32 pb-8">

    <!-- Header -->
    <section class="pt-10 pb-16">
      <h1 class="font-serif text-6xl md:text-7xl font-bold text-gray-900 leading-none tracking-tight mb-5">
        Research
      </h1>
      <p class="text-gray-500 text-[1.05rem] max-w-2xl leading-relaxed">
        {profile.researchStatement}{' '}
        <a
          href={profile.googleScholar}
          target="_blank"
          rel="noopener noreferrer"
          class="text-indigo-600 hover:underline underline-offset-2"
        >
          Google Scholar →
        </a>
      </p>
    </section>

    <div class="h-px bg-gradient-to-r from-gray-200 via-gray-300 to-gray-200 mb-16"></div>

    <!-- Publications -->
    <section>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-6">
        Publications
      </p>
      <div class="space-y-4">
        {
          publications.map((pub) => (
            <PublicationCard
              title={pub.title}
              authors={pub.authors}
              venue={pub.venue}
              year={pub.year}
              link={pub.link}
              bibtex={pub.bibtex}
              abstract={pub.abstract}
            />
          ))
        }
      </div>
    </section>

  </main>

  <Footer />
</Layout>
